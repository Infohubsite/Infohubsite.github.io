@inject IEntityInstanceService EIS

@if (loading)
{
    <MudText Typo="Typo.body2" Class="font-italic">...</MudText>
}
else
{
    <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" Color="Color.Primary" />
    if (error != null)
    {
        <MudText Typo="Typo.body2" Color="Color.Error">@error</MudText>
    }
    else if (refInstance != null)
    {
        <MudText Typo="Typo.body2">@name</MudText>
    }
}
@code {
    [Parameter, EditorRequired] public Guid InstanceId { get; set; }

    private bool loading = true;
    private EntityInstance? refInstance;
    private string name = string.Empty;
    private string? error;

    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        error = null;
        refInstance = null;

        Result<EntityInstance> result = await EIS.GetInstanceAsync(InstanceId);
        if (result.IsSuccess)
        {
            refInstance = result.Value;
            name = InstanceUtils.GetDisplayName(refInstance);
        }
        else error = $"({(result.StatusCode != System.Net.HttpStatusCode.NotFound && result.Exception != null ? result.Exception.Message : "Instance")} {InstanceId.ToString().Substring(0, 8)}...)";

        loading = false;
    }
}