<MudSimpleTable Dense="true" Hover="true">
    <MudCardContent>
        <MudStack Spacing="1">
            @foreach (FieldDefinition field in EntityDefinition.Fields.OrderBy(f => f.Name))
            {
                <MudStack Row="true" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.body2" Style="font-weight:bold; min-width: 150px;">@field.Name</MudText>
                    <CascadingValue Value="true">
                        <FieldValueDisplay Value="@EntityInstance.Data.GetValueOrDefault(field.Name)" Info="@(new FieldValueDisplay.FieldInfo { Type = field.DataType, IsList = field.IsList })" />
                    </CascadingValue>
                </MudStack>
                <MudDivider />
            }
        </MudStack>
    </MudCardContent>
</MudSimpleTable>

@code {
    [Parameter, EditorRequired] public EntityInstance EntityInstance { get; set; }
    [Parameter, EditorRequired] public EntityDefinition EntityDefinition { get; set; }
}
